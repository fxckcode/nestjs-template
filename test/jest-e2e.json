{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "transformIgnorePatterns": [
    "/node_modules/",
    "/src/generated/"
  ],
  "moduleNameMapper": {
    "^\\.\\.\\/generated\\/prisma\\/client$": "<rootDir>/../__mocks__/prisma-client.ts",
    "^\\.\\.\\/\\.\\.\\/generated\\/prisma\\/client$": "<rootDir>/../__mocks__/prisma-client.ts"
  }
}
